# CNKI 自动化控制配置
CNKI_STORAGE_STATE=.cnki_storage_state.json
CNKI_DOWNLOAD_DIR=./downloads
CNKI_HEADLESS=true
CNKI_REMOTE_DEBUGGING_URL=http://localhost:9222
CNKI_USER_DATA_DIR=
CNKI_CDP_CONNECT=false
CAPTCHA_SOLVER=local
# CAPTCHA_SOLVER=2captcha
# TWOCAPTCHA_API_KEY=your_key_here
CNKI_DELAY_MIN=2.0
CNKI_DELAY_MAX=5.0
CNKI_MAX_PAGES=10
CNKI_RESULTS_PER_PAGE=20
CNKI_FILTER_CORE=true
CNKI_FILTER_CSSCI=true
